# ── Glass backend ──────────────────────────────────────────────────────────
GLASS_API_URL=http://127.0.0.1:8000

# ── LiveKit ────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_SERVER_URL=wss://your-livekit-server.com

# ── Gemini Live ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── FCM (Android push) ─────────────────────────────────────────────────────
# Path to your Firebase service account JSON file
FIREBASE_CREDENTIALS_JSON=/etc/silicon-ring/firebase-adminsdk.json

# ── APNs (iOS VoIP push) ───────────────────────────────────────────────────
APNS_KEY_FILE=/etc/silicon-ring/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
# iOS app bundle ID (must have VoIP entitlement)
APNS_TOPIC=com.yourcompany.glass
# Set to true to use APNs sandbox (development builds)
APNS_USE_SANDBOX=false

# ── silicon-ring security ──────────────────────────────────────────────────
# Random 32+ byte hex string — signs ring_tokens embedded in push payloads
RING_HMAC_SECRET=change-me-in-production

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8010
# Seconds before a ringing call is auto-marked as missed
RING_TIMEOUT_SECONDS=60
